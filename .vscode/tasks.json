		{
			"label": "Validate HTML head tags",
			"type": "shell",
			"command": "powershell.exe",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$files = Get-ChildItem -Recurse -File -Filter *.html; $missingCharset=@(); $missingStyle=@(); foreach($f in $files){ $c = Get-Content -Raw -Path $f.FullName; if($c -notmatch '(?is)<meta\\s+charset\\s*=\\s*[\"'']?utf-8'){ $missingCharset += $f.FullName }; if($c -notmatch '(?is)<link\\s+[^>]*href\\s*=\\s*[\"''][^\"'']*style\\.css'){ $missingStyle += $f.FullName } }; Write-Output \"missing charset: $($missingCharset.Count)\"; $missingCharset | Select-Object -First 20; Write-Output \"missing style: $($missingStyle.Count)\"; $missingStyle | Select-Object -First 20"
			],
			"problemMatcher": [],
			"group": "build"
		},
